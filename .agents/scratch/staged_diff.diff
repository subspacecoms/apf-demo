+      store.setState({
+        activeTour: "catalog",
+        currentStep: 1
+      })
+      const spyNext = vi.spyOn(store.getState(), "nextStep")
+      
+      store.getState().advanceStep("catalog", 2)
+      
+      expect(spyNext).not.toHaveBeenCalled()
+      spyNext.mockRestore()
+    })
+  })
+})
